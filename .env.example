# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: ollama | groq | together
LLM_PROVIDER=ollama

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# Groq (fast cloud inference)
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Together.ai
TOGETHER_API_KEY=your_key_here
TOGETHER_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default — use a CoSQL fixture or your own .db file)
DATABASE_URL=sqlite:///data/cosql/databases/concert_singer/concert_singer.db
# PostgreSQL (set dialect=postgres in the runner if using this)
# DATABASE_URL=postgresql://user:password@localhost:5432/yourdb

# ── Pipeline settings ─────────────────────────────────────────────────────────
MAX_RETRY_ATTEMPTS=3
SCHEMA_CACHE_TTL_SECONDS=300
CONFIDENCE_THRESHOLD=0.7
